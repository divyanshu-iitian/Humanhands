{
  "name": "@humanhands/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify API service — exposes deterministic browser automation over HTTP",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean --no-splitting --external playwright --external @playwright/test",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@humanhands/shared-types": "workspace:*",
    "@humanhands/executor": "workspace:*",
    "@humanhands/event-system": "workspace:*",
    "@humanhands/ui-graph": "workspace:*",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "playwright": "^1.48.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
