{
  "name": "@humanhands/workflow-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "Captures user interactions as immutable action event streams for workflow compilation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@humanhands/shared-types": "workspace:*",
    "@humanhands/event-system": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "vitest": "^2.1.4"
  }
}
